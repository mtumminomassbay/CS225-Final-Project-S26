<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>

<!-- Gabriel Ferreira -->
<VBox prefHeight="400.0" prefWidth="200.0" spacing="7.0" style="-fx-background-color: #f4f7fb; -fx-border-color: #c8d3df; -fx-border-width: 1 0 0 1;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="SimulationController">
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
   <children>
      <Label text="Simulation Controls" style="-fx-font-size: 16px; -fx-font-weight: bold;" wrapText="true" />
      <Label fx:id="currentStageLabel" text="Stage: Group Stage" wrapText="true" />
      <Label fx:id="selectedContextLabel" text="Selected: No group selected" wrapText="true" />
      <Label fx:id="nextMatchLabel" text="Next match: Placeholder" wrapText="true" />
      <Label fx:id="progressLabel" text="Progress: 0 placeholder matches simulated" wrapText="true" />
      <Separator />
      <Button fx:id="simulateNextMatchButton" maxWidth="Infinity" mnemonicParsing="false" text="Simulate Next Match" wrapText="true" />
      <Button fx:id="simulateCurrentGroupButton" maxWidth="Infinity" mnemonicParsing="false" text="Simulate Current Group" wrapText="true" />
      <Button fx:id="simulateCurrentRoundButton" maxWidth="Infinity" mnemonicParsing="false" text="Simulate Current Round" wrapText="true" />
      <Button fx:id="simulateRestOfTournamentButton" maxWidth="Infinity" mnemonicParsing="false" text="Simulate Rest of Tournament" wrapText="true" />
      <Button fx:id="autoPlayButton" maxWidth="Infinity" mnemonicParsing="false" text="Auto Play" />
      <Button fx:id="pauseButton" maxWidth="Infinity" mnemonicParsing="false" text="Pause" />
      <Button fx:id="resetCurrentContextButton" maxWidth="Infinity" mnemonicParsing="false" text="Reset Current Group" wrapText="true" />
      <Button fx:id="resetTournamentButton" maxWidth="Infinity" mnemonicParsing="false" text="Reset Tournament" wrapText="true" />
      <Label text="Speed" />
      <ComboBox fx:id="speedComboBox" maxWidth="Infinity" />
      <Label fx:id="statusLabel" text="Ready." wrapText="true" style="-fx-font-style: italic;" />
   </children>
</VBox>
