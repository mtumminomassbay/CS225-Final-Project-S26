<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="860.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="DashboardController">
    <children>
        <Label layoutX="182.0" layoutY="14.0" styleClass="title-label" text="Dashboard" />
        <Label layoutX="151.0" layoutY="351.0" styleClass="title-label" text="Tournament Status" />
        <Label fx:id="statusLabel" layoutX="153.0" layoutY="381.0" styleClass="body-label" text="Status: Not Started" />
        <Label fx:id="currentStageLabel" layoutX="153.0" layoutY="406.0" styleClass="body-label" text="Current Stage: Group Stage" />
        <Label fx:id="groupsCompletedLabel" layoutX="153.0" layoutY="431.0" styleClass="body-label" text="Groups Completed: 0/8" />
        <Label layoutX="182.0" layoutY="95.0" styleClass="title-label" text="Navigation" />
        <Button fx:id="GroupStage_Button" layoutX="150.0" layoutY="125.0" mnemonicParsing="false" onAction="#GroupStageButton_clicked" prefWidth="150.0" text="Group Stage" />
        <Button fx:id="KnockoutPhase_Button" layoutX="150.0" layoutY="168.0" mnemonicParsing="false" onAction="#KnockoutPhaseButton_clicked" prefWidth="150.0" text="Knockout Rounds" />
        <Button fx:id="TeamInfo_Button" layoutX="150.0" layoutY="211.0" mnemonicParsing="false" onAction="#TeamInfoButton_clicked" prefWidth="150.0" text="Team Info" />
        <ImageView fx:id="AllStar_ImageView" fitHeight="524.0" fitWidth="348.0" layoutY="35.0" pickOnBounds="true" preserveRatio="true" AnchorPane.bottomAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="35.0">
            <image>
                <Image url="@AllStars/ChristianoRonaldo.png" />
            </image>
        </ImageView>
    </children>
</AnchorPane>
