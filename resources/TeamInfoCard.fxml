            <Label fx:id="countryName" layoutX="13.0" layoutY="29.0" prefHeight="54.0" prefWidth="166.0" text="Country Name">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            <ImageView fx:id="flagImage" fitHeight="19.0" fitWidth="37.0" layoutX="146.0" layoutY="13.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@flags/test%20flag.png" />
               </image>
            </ImageView>
         </children>
      </Pane>
      <Pane layoutY="89.0" prefHeight="67.0" prefWidth="191.0" style="-fx-background-color: white;">
         <children>
            <Text fx:id="GROUP_STAGE_TEXT" layoutX="14.0" layoutY="24.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Stage">
               <font>
                  <Font size="14.0" />
