<AnchorPane fx:id="cardPane" onMousePressed="#cardClicked" prefHeight="156.0" prefWidth="190.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="TeamInfoCard">
