<AnchorPane fx:id="cardPane" onMousePressed="#cardClicked" prefHeight="156.0" prefWidth="190.0" style="-fx-border-color: #0f4910; -fx-border-width: 1.5px; -fx-border-radius: 8px; -fx-background-radius: 8px;" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="TeamInfoCardController">
