                  <Font size="14.0" />
               </font>
            </Text>
            <Text fx:id="CONFEDERATION_TEXT" layoutX="13.0" layoutY="54.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Confederation">
               <font>
                  <Font size="14.0" />
               </font>
            </Text>
            <Text fx:id="confederationName" layoutX="141.0" layoutY="54.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Name">
               <font>
                  <Font size="14.0" />
               </font>
            </Text>
         </children>
      </Pane>
   </children>
</AnchorPane>
